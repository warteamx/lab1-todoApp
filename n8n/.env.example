# ==============================================
# n8n Docker Environment Configuration
# ==============================================

# Database Configuration
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=your_secure_password_here

# n8n Basic Authentication (recommended for production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_admin_password_here

# n8n Host Configuration
# For local development
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# For AWS EC2 deployment (update with your domain/IP)
# N8N_HOST=your-domain.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://your-domain.com

# n8n General Configuration
GENERIC_TIMEZONE=America/New_York
N8N_LOG_LEVEL=info

# Execution Data Management
N8N_EXECUTION_DATA_PRUNE=true
N8N_EXECUTION_DATA_MAX_AGE=168  # 7 days in hours

# Security Settings
N8N_SECURE_COOKIE=false  # Set to true for HTTPS in production

# Performance Settings
N8N_RUNNERS_ENABLED=true
DB_SQLITE_POOL_SIZE=10

# Node Security
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_GIT_NODE_DISABLE_BARE_REPOS=true

# File Permissions
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# ==============================================
# Production Environment Variables
# (Uncomment and configure for AWS EC2)
# ==============================================

# SSL/HTTPS Configuration
# N8N_SECURE_COOKIE=true
# N8N_PROTOCOL=https

# Domain Configuration
# N8N_HOST=n8n.your-domain.com
# WEBHOOK_URL=https://n8n.your-domain.com

# Email Configuration (for notifications)
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.gmail.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=your-email@gmail.com
# N8N_SMTP_PASS=your-app-password
# N8N_SMTP_SENDER=your-email@gmail.com

# External Storage (AWS S3)
# N8N_DEFAULT_BINARY_DATA_MODE=filesystem
# N8N_BINARY_DATA_S3_BUCKET=your-n8n-bucket
# N8N_BINARY_DATA_S3_REGION=us-east-1
# N8N_BINARY_DATA_S3_ACCESS_KEY=your-access-key
# N8N_BINARY_DATA_S3_SECRET_KEY=your-secret-key

# Monitoring and Logging
# N8N_METRICS=true
# N8N_LOG_LEVEL=warn

# Queue Management (with Redis)
# QUEUE_BULL_REDIS_HOST=redis
# QUEUE_BULL_REDIS_PORT=6379
# QUEUE_BULL_REDIS_PASSWORD=

# Advanced Security
# N8N_JWT_AUTH_ACTIVE=true
# N8N_JWT_AUTH_HEADER=authorization
# N8N_JWT_AUTH_HEADER_VALUE_PREFIX=Bearer
